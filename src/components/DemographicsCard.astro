---
import demographicsData from '../data/iran-policy-demographics.json';

const defaultMode = demographicsData.modes?.[0]?.id || 'all_americans';
const defaultDimension =
  demographicsData.defaultDemographic || demographicsData.dimensions?.[0]?.id || '';
---

<section class="demographics-card" data-demographics-card>
  <div class="card-head">
    <p class="card-label">Demographics</p>
    <div class="mode-switch" role="tablist" aria-label="Response universe">
      {demographicsData.modes.map((mode, idx) => (
        <button
          type="button"
          class:list={['mode-btn', idx === 0 && 'is-active']}
          data-mode-btn
          data-mode={mode.id}
          aria-pressed={idx === 0 ? 'true' : 'false'}
        >
          {mode.label}
        </button>
      ))}
    </div>
  </div>

  <div class="controls">
    <label class="control-item">
      <span>Demographic</span>
      <select data-dim-select>
        {demographicsData.dimensions.map((dimension) => (
          <option value={dimension.id} selected={dimension.id === defaultDimension}>
            {dimension.label}
          </option>
        ))}
      </select>
    </label>
    <label class="control-item">
      <span>Response category</span>
      <select data-metric-select></select>
    </label>
  </div>

  <p class="metric-caption" data-metric-caption></p>
  <div class="rows" data-rows></div>
  <p class="footnote">Values are weighted poststratified estimates (percent).</p>
</section>

<script define:vars={{ demographicsData, defaultMode, defaultDimension }}>
  const toNum = (value) => {
    if (value === null || value === undefined || value === '') return null;
    const n = Number(value);
    return Number.isFinite(n) ? n : null;
  };

  const fmtPct = (value) => `${value.toFixed(1)}%`;
  const fmtDelta = (value) => `${value > 0 ? '+' : ''}${value.toFixed(1)}pp`;

  document.querySelectorAll('[data-demographics-card]').forEach((card) => {
    const dimSelect = card.querySelector('[data-dim-select]');
    const metricSelect = card.querySelector('[data-metric-select]');
    const metricCaption = card.querySelector('[data-metric-caption]');
    const rowsRoot = card.querySelector('[data-rows]');
    const modeButtons = Array.from(card.querySelectorAll('[data-mode-btn]'));

    const dimensions = Array.isArray(demographicsData.dimensions)
      ? demographicsData.dimensions
      : [];

    if (!dimSelect || !metricSelect || !metricCaption || !rowsRoot || dimensions.length === 0) {
      return;
    }

    let activeMode = defaultMode;
    let activeDimensionId = defaultDimension;
    let activeMetricId = demographicsData.defaultMetric || '';

    const getDimension = () => {
      return dimensions.find((dimension) => dimension.id === activeDimensionId) || dimensions[0];
    };

    const syncMetricOptions = () => {
      const dimension = getDimension();
      const metrics = Array.isArray(dimension?.metrics) ? dimension.metrics : [];
      metricSelect.innerHTML = '';
      metrics.forEach((metric) => {
        const option = new Option(metric.label, metric.id);
        metricSelect.appendChild(option);
      });

      const hasActive = metrics.some((metric) => metric.id === activeMetricId);
      activeMetricId = hasActive
        ? activeMetricId
        : metrics.find((metric) => metric.id === demographicsData.defaultMetric)?.id ||
          metrics[0]?.id ||
          '';

      metricSelect.value = activeMetricId;
    };

    const renderRows = () => {
      const dimension = getDimension();
      const metrics = Array.isArray(dimension?.metrics) ? dimension.metrics : [];
      const metric = metrics.find((m) => m.id === activeMetricId) || metrics[0];

      if (!metric) {
        rowsRoot.innerHTML = '<p class="empty">No metric data available.</p>';
        metricCaption.textContent = '';
        return;
      }

      metricCaption.textContent = metric.label;

      const models = (dimension.rows || [])
        .map((row) => {
          const bucket = row?.values?.[metric.id]?.[activeMode] || {};
          return {
            label: row?.label || row?.id || 'Unknown',
            current: toNum(bucket.current),
            prior: toNum(bucket.prior),
          };
        })
        .filter((entry) => entry.current !== null);

      rowsRoot.innerHTML = '';

      if (models.length === 0) {
        rowsRoot.innerHTML = '<p class="empty">No data available for this selection.</p>';
        return;
      }

      const maxVal = Math.max(
        1,
        ...models.flatMap((entry) => [entry.current, entry.prior].filter((value) => value !== null))
      );

      models.forEach((entry) => {
        const currentPct = (entry.current / maxVal) * 100;
        const priorPct = entry.prior === null ? 0 : (entry.prior / maxVal) * 100;
        const delta = entry.prior === null ? null : entry.current - entry.prior;

        const row = document.createElement('div');
        row.className = 'demo-row';

        const left = document.createElement('div');
        left.className = 'demo-row-left';

        const label = document.createElement('span');
        label.className = 'demo-label';
        label.textContent = entry.label;

        const track = document.createElement('span');
        track.className = 'demo-track';

        const priorFill = document.createElement('span');
        priorFill.className = 'demo-fill demo-fill-prior';
        priorFill.style.width = `${priorPct.toFixed(2)}%`;
        priorFill.style.background = metric.color;

        const currentFill = document.createElement('span');
        currentFill.className = 'demo-fill demo-fill-current';
        currentFill.style.width = `${currentPct.toFixed(2)}%`;
        currentFill.style.background = metric.color;

        track.appendChild(priorFill);
        track.appendChild(currentFill);

        left.appendChild(label);
        left.appendChild(track);

        const values = document.createElement('span');
        values.className = 'demo-values';

        const main = document.createElement('span');
        main.className = 'demo-main';
        main.textContent = fmtPct(entry.current);
        values.appendChild(main);

        if (delta !== null) {
          const deltaEl = document.createElement('span');
          deltaEl.className = 'demo-delta';
          if (delta > 0) deltaEl.classList.add('is-up');
          if (delta < 0) deltaEl.classList.add('is-down');
          if (delta === 0) deltaEl.classList.add('is-flat');
          deltaEl.textContent = fmtDelta(delta);
          values.appendChild(deltaEl);
        }

        row.appendChild(left);
        row.appendChild(values);
        rowsRoot.appendChild(row);
      });
    };

    const render = () => {
      modeButtons.forEach((btn) => {
        const active = btn.dataset.mode === activeMode;
        btn.classList.toggle('is-active', active);
        btn.setAttribute('aria-pressed', active ? 'true' : 'false');
      });
      renderRows();
    };

    dimSelect.addEventListener('change', () => {
      activeDimensionId = dimSelect.value;
      syncMetricOptions();
      render();
    });

    metricSelect.addEventListener('change', () => {
      activeMetricId = metricSelect.value;
      render();
    });

    modeButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        activeMode = btn.dataset.mode || 'all_americans';
        render();
      });
    });

    syncMetricOptions();
    render();
  });
</script>

<style>
  .demographics-card {
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-lg);
    background: var(--color-surface);
    padding: var(--space-lg);
    margin: var(--space-xl) 0;
    box-shadow: 0 6px 20px var(--color-card-shadow);
  }

  .card-head {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }

  .card-label {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0;
  }

  .mode-switch {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    border: 1px solid var(--color-border);
    border-radius: 9999px;
    padding: 0.2rem;
    background: var(--color-surface-hover);
  }

  .mode-btn {
    border: 0;
    border-radius: 9999px;
    background: transparent;
    color: var(--color-text-secondary);
    font-size: 0.72rem;
    line-height: 1;
    font-weight: 600;
    padding: 0.45rem 0.65rem;
    cursor: pointer;
    transition: background var(--transition-fast), color var(--transition-fast);
  }

  .mode-btn.is-active {
    background: var(--color-surface);
    color: var(--color-text);
  }

  .controls {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .control-item {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .control-item span {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .control-item select {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    color: var(--color-text);
    font-size: 0.8rem;
    padding: 0.45rem 0.55rem;
  }

  .metric-caption {
    margin: 0 0 var(--space-sm);
    font-size: 0.84rem;
    color: var(--color-text-secondary);
  }

  .rows {
    display: grid;
    gap: var(--space-sm);
  }

  .demo-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
  }

  .demo-row-left {
    flex: 1;
    min-width: 0;
  }

  .demo-label {
    display: block;
    font-size: 0.84rem;
    color: var(--color-text-secondary);
    margin-bottom: 0.33rem;
  }

  .demo-track {
    position: relative;
    display: block;
    height: 0.62rem;
    border-radius: 9999px;
    overflow: hidden;
    background: var(--color-border-light);
  }

  .demo-fill {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    border-radius: 9999px;
  }

  .demo-fill-prior {
    opacity: 0.4;
  }

  .demo-fill-current {
    opacity: 0.95;
  }

  .demo-values {
    width: 5.2rem;
    text-align: right;
    flex-shrink: 0;
    font-variant-numeric: tabular-nums;
  }

  .demo-main {
    display: block;
    font-size: 0.84rem;
    font-weight: 700;
    line-height: 1.1;
    color: var(--color-text);
  }

  .demo-delta {
    display: block;
    margin-top: 0.1rem;
    font-size: 0.74rem;
    line-height: 1.1;
    color: var(--color-text-muted);
  }

  .demo-delta.is-up {
    color: #a24f1e;
  }

  .demo-delta.is-down {
    color: #2a6b77;
  }

  .footnote {
    margin: var(--space-md) 0 0;
    font-size: 0.74rem;
    color: var(--color-text-muted);
  }

  .empty {
    color: var(--color-text-muted);
    font-size: 0.84rem;
    font-style: italic;
    margin: 0;
  }

  @media (max-width: 720px) {
    .demographics-card {
      padding: var(--space-md);
    }

    .controls {
      grid-template-columns: 1fr;
    }

    .demo-values {
      width: 4.6rem;
    }
  }
</style>
