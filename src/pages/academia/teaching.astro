    margin-bottom: 0.15rem;
  }

  .course-meta {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-sm);
  }

  .course-links {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }
</style>
