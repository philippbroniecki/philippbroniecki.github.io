---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About – Philipp Broniecki" description="Data scientist specialising in survey methodology, public opinion measurement, and applied machine learning. Currently at Vantage Data House.">
  <div class="about-hero">
    <div class="container">
      <h1>About me</h1>
    </div>
  </div>

  <div class="container about-body">
    <div class="about-grid">
      <!-- Photo -->
      <div class="about-photo-col">
        <img
          src="/images/profile.jpg"
          alt="Philipp Broniecki"
          class="about-photo"
          width="360"
          height="360"
        />
      </div>

      <!-- Bio -->
      <div class="about-text-col prose">
        <p>
          I am a data scientist specialising in survey methodology, public
          opinion measurement, and applied machine learning. Currently, at
          Vantage Data House I set up a survey analytics pipeline for a
          real-time public opinion forecasting platform.
        </p>
        <p>
          Previously, I held academic positions at the University of Oslo,
          Essex University, University College London (UCL), and the Hertie School,
          where I researched legislative politics in the European Union and
          developed statistical methods for estimating subnational public
          opinion. I hold a PhD from UCL and an MA from the University of
          Mannheim.
        </p>
        <p>
          Feel free to get in touch directly.
        </p>

        <!-- Social / contact links -->
        <div class="social-links">
          <a href="mailto:philippbroniecki@gmail.com" class="social-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            Email
          </a>
          <a href="https://bsky.app/profile/philippbroniecki.bsky.social" target="_blank" rel="noopener noreferrer" class="social-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.5 2 3.8 6.7 3 8.5c-.2.5-.3 1-.3 1s1.2 7.5 4 9c1.5.8 3.2.3 4.2-.5.3-.3.6-.6.8-1 .1.3.3.6.5.8 1 1 2.8 1.5 4.5.7 2.8-1.4 4-9 4-9s-.1-.5-.3-1C19.5 6.7 17.5 2 12 2z"/></svg>
            Bluesky
          </a>
          <a href="https://x.com/PhilippBronieck" target="_blank" rel="noopener noreferrer" class="social-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            X
          </a>
          <a href="https://www.linkedin.com/in/philipp-broniecki-8531a395/" target="_blank" rel="noopener noreferrer" class="social-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.5 2h-17A1.5 1.5 0 002 3.5v17A1.5 1.5 0 003.5 22h17a1.5 1.5 0 001.5-1.5v-17A1.5 1.5 0 0020.5 2zM8 19H5v-9h3zM6.5 8.25A1.75 1.75 0 118.3 6.5a1.78 1.78 0 01-1.8 1.75zM19 19h-3v-4.74c0-1.42-.6-1.93-1.38-1.93A1.74 1.74 0 0013 14.19V19h-3v-9h2.9v1.3a3.11 3.11 0 012.7-1.4c1.55 0 3.36.86 3.36 3.66z"/></svg>
            LinkedIn
          </a>
          <a href="/blog/" class="social-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M8 13h8"/><path d="M8 17h8"/><path d="M8 9h2"/></svg>
            My blog: Mostly Noise
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .about-hero {
    background: var(--color-hero-bg);
    color: var(--color-hero-text);
    padding: var(--space-2xl) 0;
  }

  .about-hero h1 {
    color: var(--color-hero-text);
    font-size: 1.75rem;
    font-weight: 700;
  }

  .about-body {
    padding-top: var(--space-2xl);
    padding-bottom: var(--space-2xl);
  }

  .about-grid {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-2xl);
    align-items: start;
  }

  .about-photo {
    width: 220px;
    height: auto;
    border-radius: var(--radius-lg);
    object-fit: cover;
    border: 1px solid var(--color-border-light);
  }

  /* Social link buttons */
  .social-links {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
    margin-top: var(--space-lg);
    margin-bottom: var(--space-lg);
  }

  .social-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    font-size: 0.825rem;
    font-weight: 500;
    padding: 0.45em 0.9em;
    border-radius: 9999px;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .social-btn:hover {
    background: var(--color-surface-hover);
    color: var(--color-text);
    text-decoration: none;
  }

  .social-btn svg {
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .about-grid {
      grid-template-columns: 1fr;
      justify-items: center;
      text-align: left;
    }

    .about-photo {
      width: 180px;
    }

    .social-links {
      justify-content: flex-start;
    }
  }
</style>
