---
import BaseLayout from '../layouts/BaseLayout.astro';
import Card from '../components/Card.astro';

/* Vantage Insights URL — change this one variable when the domain moves */
const vantageInsightsUrl = 'https://vantage.philippbroniecki.com';
const autoMrPUrl = 'https://cran.r-project.org/package=autoMrP';
---

<BaseLayout title="Philipp Broniecki – Data Science & Polling">
  <!-- Hero -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-text">
        <p class="hero-label">Philipp Broniecki</p>
        <h1>Data Science, Polling &amp;&nbsp;Public&nbsp;Opinion</h1>
        <p class="hero-sub">
          I work at the intersection of data science, polling methodology, and
          public opinion research. My current work focuses on building a survey analytics and forecasting pipeline at <a href="https://www.vantagedatahouse.com" target="_blank" rel="noopener noreferrer">
            Vantage Data House</a>. Previously, from 2014 to 2025, I worked in academia.
        </p>
      </div>
    </div>
  </section>

  <!-- Main cards -->
  <section class="container cards-section">
    <p class="section-label">About</p>
    <div class="card-grid cols-2">
      <Card
        title="About me"
        description="Data scientist specialising in survey methodology, public opinion measurement, and applied machine learning. Bio, contact details, and social links."
        href="/about/"
        tags={['bio', 'contact']}
      />
    </div>

    <p class="section-label" style="margin-top: var(--space-2xl);">Current Work</p>
    <div class="card-grid cols-2">
      <Card
        title="Vantage Data House Insights"
        description="Interactive polling reports, favorability, current-events, and high-level time series. Requires a Vantage Data House email. Access can also be requested."
        href={vantageInsightsUrl}
        tags={['polling', 'data']}
        external
      />
      <Card
        title="Blog"
        description="Writing on data science, methodology, polling, and things I find interesting."
        href="/blog/"
        tags={['blog']}
      />
      <Card
        title="autoMrP"
        description="R software package to estimate subnational public opinion from surveys. Available on CRAN and GitHub. Update coming soon."
        href={autoMrPUrl}
        tags={['R', 'software']}
        external
      />
    </div>

    <p class="section-label" style="margin-top: var(--space-2xl);">Academia: My previous work in academia</p>
    <div class="card-grid cols-2">
      <Card
        title="Research"
        description="Publications, working papers, and ongoing academic projects in political science, EU legislative politics, and quantitative methodology."
        href="/academia/research/"
        tags={['publications', 'working papers']}
      />
      <Card
        title="Teaching"
        description="Courses I have taught or assisted with in statistics, data science, programming, and political science at several universities."
        href="/academia/teaching/"
        tags={['courses', 'workshops']}
      />
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    background: var(--color-hero-bg);
    color: var(--color-hero-text);
    padding: var(--space-3xl) 0;
  }

  .hero-inner {
    max-width: var(--content-width);
  }

  .hero-label {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .hero h1 {
    color: var(--color-hero-text);
    font-size: clamp(1.6rem, 4vw, 2.25rem);
    font-weight: 750;
    line-height: 1.2;
    margin-bottom: var(--space-lg);
  }

  .hero-sub {
    color: var(--color-text-muted);
    font-size: 1rem;
    line-height: 1.7;
    max-width: 40rem;
  }

  .hero-sub a {
    color: var(--color-accent);
    font-weight: 500;
  }

  .cards-section {
    padding: var(--space-2xl) var(--space-xl) var(--space-3xl);
  }

  .card-grid {
    display: grid;
    gap: var(--space-lg);
  }

  .card-grid.cols-2 {
    grid-template-columns: repeat(2, 1fr);
  }

  @media (max-width: 720px) {
    .card-grid.cols-2 {
      grid-template-columns: 1fr;
    }

    .hero {
      padding: var(--space-2xl) 0;
    }
  }
</style>
